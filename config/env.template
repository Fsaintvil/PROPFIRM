# Template de configuration environnement — Robot MOM20x3
# Copier vers .env et remplir avec vos valeurs
# Les variables ${VAR} dans config/default.yaml sont interpolées depuis .env
#
# Utilisation réelle (vérifiée par code review) :
#   config/schema.py     → os.getenv() pour secrets (MT5_LOGIN, etc.)
#   config_simple.py     → load_dotenv(), importe TOUT .env
#   notifier.py          → os.getenv("TELEGRAM_BOT_TOKEN")
#   mlflow_tracker.py    → os.environ.get("MLFLOW_TRACKING_URI")
#   main.py              → os.getenv("LOG_LEVEL")

# =============================================================================
#  CONFIGURATION MT5 (OBLIGATOIRE)
# =============================================================================
# Ces variables sont lues par config/schema.py via default.yaml → secrets:
MT5_LOGIN=votre_numero_compte
MT5_PASSWORD=votre_mot_de_passe
MT5_SERVER=votre_serveur_broker
# Chemin de l'exécutable MT5 (utilisé par mt5_connector.py pour lancer MT5)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# =============================================================================
#  NOTIFICATIONS TELEGRAM (OPTIONNEL)
# =============================================================================
# Lues par engine_simple/notifier.py
TELEGRAM_BOT_TOKEN=votre_token_bot
TELEGRAM_CHAT_ID=votre_chat_id

# =============================================================================
#  MLFLOW TRACKING (OPTIONNEL — réservé reprise ML)
# =============================================================================
# Lue par engine_simple/mlflow_tracker.py et engine_simple/retraining_pipeline.py
MLFLOW_TRACKING_URI=file:./mlruns

# =============================================================================
#  LOGGING (OPTIONNEL)
# =============================================================================
# Valeurs: DEBUG, INFO, WARNING, ERROR (défaut: INFO)
LOG_LEVEL=INFO
