# Template de configuration environnement PROPFIRM
# Copier vers .env et remplir avec vos valeurs

# =============================================================================
# 🔐 CONFIGURATION MT5 (OBLIGATOIRE)
# =============================================================================
MT5_LOGIN=votre_numero_compte
MT5_PASSWORD=votre_mot_de_passe
MT5_SERVER=votre_serveur_broker
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# =============================================================================
# 💰 PARAMÈTRES DE TRADING
# =============================================================================
# Risque maximum par trade (en pourcentage du capital)
MAX_RISK_PER_TRADE=2.0

# Capital de trading (si différent du compte MT5)
TRADING_CAPITAL=100000

# Instruments à trader (séparés par des virgules)
TRADING_SYMBOLS=EURUSD,XAUUSD,BTCUSD

# Taille des lots par défaut
DEFAULT_LOT_SIZE=0.01

# =============================================================================
# 🧠 CONFIGURATION IA
# =============================================================================
# Seuil de confiance minimum pour les trades
CONFIDENCE_THRESHOLD=0.50

# Activer/désactiver les modules IA
ENABLE_META_LEARNING=true
ENABLE_REINFORCEMENT_LEARNING=true
ENABLE_REGIME_DETECTION=true
ENABLE_PORTFOLIO_OPTIMIZER=true

# =============================================================================
# 📊 LOGGING ET MONITORING
# =============================================================================
# Niveau de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Activer logs compression
ENABLE_LOG_COMPRESSION=true

# Nombre maximum de fichiers de log à conserver
MAX_LOG_FILES=10

# =============================================================================
# 🔔 NOTIFICATIONS (OPTIONNEL)
# =============================================================================
# Telegram Bot
TELEGRAM_BOT_TOKEN=votre_token_bot
TELEGRAM_CHAT_ID=votre_chat_id

# Slack (optionnel)
SLACK_WEBHOOK_URL=votre_webhook_slack

# Email SMTP (optionnel)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app

# =============================================================================
# 🌐 API EXTERNES (OPTIONNEL)
# =============================================================================
# OpenAI pour analyse sentiment
OPENAI_API_KEY=votre_cle_openai

# Alpha Vantage pour données supplémentaires
ALPHA_VANTAGE_API_KEY=votre_cle_alpha_vantage

# =============================================================================
# 🏃 MODE OPÉRATIONNEL
# =============================================================================
# Mode: production, development, testing
ENVIRONMENT=development

# Activer trading live (true) ou simulation (false)
LIVE_TRADING=false

# Intervalle entre analyses (en secondes)
TRADING_INTERVAL=930

# =============================================================================
# 🗄️ BASE DE DONNÉES (OPTIONNEL)
# =============================================================================
# SQLite par défaut, PostgreSQL pour production
DATABASE_URL=sqlite:///data/trading.db

# =============================================================================
# 🔧 PARAMÈTRES AVANCÉS
# =============================================================================
# Timeout connexion MT5 (secondes)
MT5_TIMEOUT=30

# Nombre de retry connexion
MT5_RETRY_COUNT=3

# Utiliser GPU pour TensorFlow/PyTorch
USE_GPU=false

# Seed pour reproductibilité
RANDOM_SEED=42